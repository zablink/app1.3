# Copy to .env.local (recommended) or .env
# Never commit real secrets.

# App URLs
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# Auth (NextAuth)
NEXTAUTH_SECRET=replace_with_random_32+_chars

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# TikTok OAuth
TIKTOK_CLIENT_KEY=
# Alternative name supported by code:
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
# If not set, app constructs from NEXT_PUBLIC_APP_URL/NEXTAUTH_URL + /api/auth/tiktok/callback
TIKTOK_REDIRECT_URI=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Payments (Omise)
OMISE_PUBLIC_KEY=
OMISE_SECRET_KEY=

# Debug endpoints (required to access debug routes in production; otherwise they return 404)
DEBUG_API_SECRET=

# Optional (image generation scripts)
OPENAI_API_KEY=
HUGGINGFACE_API_KEY=
GROK_API_KEY=
XAI_API_KEY=
